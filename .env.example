# ──────────────────────────────────────────────────
# DATABASE (Neon Postgres)
# ──────────────────────────────────────────────────
# Serverless HTTP URL — used at runtime on the edge (Neon HTTP driver)
DATABASE_URL="postgres://user:password@host.neon.tech/pixelholiday_os?sslmode=require"

# Direct TCP connection — used by Prisma CLI (migrate, db push, studio, seed)
# Same host/db as DATABASE_URL but must be postgresql:// scheme
DATABASE_DIRECT_URL="postgresql://user:password@host.neon.tech/pixelholiday_os?sslmode=require"

# ──────────────────────────────────────────────────
# NEXT AUTH v5
# ──────────────────────────────────────────────────
# Generate secret with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://yourdomain.com"

# NextAuth v4-style aliases — required by some adapters and CI workflows
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://yourdomain.com"

# ──────────────────────────────────────────────────
# STRIPE
# ──────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ──────────────────────────────────────────────────
# UPSTASH REDIS (session store, rate limiting, caching)
# ──────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://...redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# ──────────────────────────────────────────────────
# RESEND (email service)
# ──────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ──────────────────────────────────────────────────
# OPENAI (GPT-4 for product descriptions, etc.)
# ──────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ──────────────────────────────────────────────────
# CLOUDFLARE PAGES (deploy.sh uses this)
# ──────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID="..."
CLOUDFLARE_API_TOKEN="..."
CLOUDFLARE_PROJECT_NAME="pixelholiday-os"

# ──────────────────────────────────────────────────
# GITHUB (for GH_TOKEN in deploy.sh)
# ──────────────────────────────────────────────────
GH_TOKEN="ghp_..."

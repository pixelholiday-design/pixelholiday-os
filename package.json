{
  "name": "pixelholiday-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cf:build": "prisma generate && npx @cloudflare/next-on-pages",
    "cf:preview": "npm run cf:build && wrangler pages dev",
    "cf:deploy": "wrangler pages deploy .vercel/output/static",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@cloudflare/next-on-pages": "^1.13.12",
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.460.0",
    "next": "^14.2.29",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.29",
    "prisma": "^5.22.0",
    "typescript": "^5.7.2",
    "vercel": "^39.3.0",
    "vitest": "^2.1.8",
    "wrangler": "^3.101.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
